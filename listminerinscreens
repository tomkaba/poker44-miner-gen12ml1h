#!/usr/bin/env bash
set -euo pipefail

TAIL_LINES="${TAIL_LINES:-400}"

usage() {
  cat <<'EOF'
Usage:
  ./listminerinscreens

Optional env:
  TAIL_LINES=400   Number of recent screen lines to scan for "Miner UID: <n>"
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

list_socket_sessions() {
  local sock_dir="/run/screen/S-${USER}"

  [[ -d "$sock_dir" ]] || return 0

  # Emit: full_session|short_session (e.g. 1127451.sn126_m62|sn126_m62)
  ls -1 "$sock_dir" 2>/dev/null \
    | sed -nE 's/^([0-9]+\.(sn126[^[:space:]]+))$/\1|\2/p' \
    | sort -t'|' -k2,2V
}

find_miner_hotkey() {
  local session="$1"
  local coldkey=""
  local miner_id=""

  # Typical session format: sn126_m6 or sn126b_m6
  if [[ "$session" =~ ^(sn126[a-z]*)_m([0-9]+)$ ]]; then
    coldkey="${BASH_REMATCH[1]}"
    miner_id="${BASH_REMATCH[2]}"
  else
    echo "-|-"
    return 0
  fi

  local hotkey="hk${miner_id}"
  local hotkey_file="${HOME}/.bittensor/wallets/${coldkey}/hotkeys/${hotkey}"
  local ss58="-"

  if [[ -r "$hotkey_file" ]]; then
    ss58="$(grep -Eo '"ss58Address"[[:space:]]*:[[:space:]]*"[^"]+"' "$hotkey_file" \
      | sed -E 's/.*"ss58Address"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/' \
      | head -n1 || true)"
    [[ -z "$ss58" ]] && ss58="-"
  fi

  echo "${hotkey}|${ss58}"
}

extract_miner_uid() {
  local full_session="$1"
  local tmp_file
  tmp_file="$(mktemp)"

  # -h includes scrollback history, not only currently visible lines.
  if ! timeout 8s screen -S "$full_session" -X hardcopy -h "$tmp_file" >/dev/null 2>&1; then
    rm -f "$tmp_file"
    echo "-"
    return 0
  fi

  local uid
  uid="$(tail -n "$TAIL_LINES" "$tmp_file" \
    | grep -Eo 'Miner UID:[[:space:]]*[0-9]+' \
    | tail -n 1 \
    | sed -E 's/.*Miner UID:[[:space:]]*([0-9]+).*/\1/' || true)"

  rm -f "$tmp_file"

  if [[ -z "$uid" ]]; then
    echo "-"
  else
    echo "$uid"
  fi
}

extract_scorer() {
  local full_session="$1"
  local tmp_file
  tmp_file="$(mktemp)"

  if ! timeout 8s screen -S "$full_session" -X hardcopy -h "$tmp_file" >/dev/null 2>&1; then
    rm -f "$tmp_file"
    echo "-"
    return 0
  fi

  local scorer
  # Try POKER44_CHUNK_SCORER init log line first (gen7heur1 etc.)
  scorer="$(tail -n "$TAIL_LINES" "$tmp_file" \
    | grep -oP "\[init\] POKER44_CHUNK_SCORER='\K[^']+" \
    | tail -n 1 || true)"

  if [[ -z "$scorer" || "$scorer" == "" ]]; then
    # Fall back to single_hand_model_alias from startup log
    scorer="$(tail -n "$TAIL_LINES" "$tmp_file" \
      | grep -oP 'alias=\K[^ ]+' \
      | tail -n 1 || true)"
  fi

  if [[ -z "$scorer" || "$scorer" == "" ]]; then
    # Fall back to periodic heartbeat log ("... | Profile: <alias> | Scorer: ...")
    scorer="$(tail -n "$TAIL_LINES" "$tmp_file" \
      | grep -oP 'Profile:[[:space:]]*\K[^| ]+' \
      | tail -n 1 || true)"
  fi

  rm -f "$tmp_file"
  echo "${scorer:--}"
}

main() {
  local sessions
  sessions="$(list_socket_sessions || true)"

  if [[ -z "$sessions" ]]; then
    echo "No active screen sessions matching sn126*"
    exit 0
  fi

  printf "%-20s | %-9s | %-14s | %-10s | %s\n" "session" "miner_uid" "scorer/profile" "hotkey" "ss58Address"
  printf "%-20s-+-%-9s-+-%-14s-+-%-10s-+-%s\n" "--------------------" "---------" "--------------" "----------" "-----------------------------------------------"

  while IFS='|' read -r full_session session; do
    [[ -z "$full_session" || -z "$session" ]] && continue

    local uid scorer hotkey_info hotkey ss58
    uid="$(extract_miner_uid "$full_session")"
    scorer="$(extract_scorer "$full_session")"
    hotkey_info="$(find_miner_hotkey "$session")"
    hotkey="${hotkey_info%%|*}"
    ss58="${hotkey_info#*|}"

    printf "%-20s | %-9s | %-14s | %-10s | %s\n" "$session" "$uid" "$scorer" "$hotkey" "$ss58"
  done <<< "$sessions"
}

main "$@"